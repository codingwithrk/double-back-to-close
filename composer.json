{
    "name": "codingwithrk/double-back-to-close",
    "description": "A NativePHP Mobile plugin that prompts users to press back twice before exiting the app.",
    "type": "nativephp-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "CodingWithRK",
            "email": "pappalarajkumar@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "nativephp/mobile": "^3.0",
        "nativephp/mobile-dialog": "^1.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Codingwithrk\\DoubleBackToClose\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Codingwithrk\\DoubleBackToClose\\DoubleBackToCloseServiceProvider"
            ]
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
